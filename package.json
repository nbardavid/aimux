{
  "name": "aimux",
  "version": "1.0.14",
  "bin": {
    "aimux": "src/index.tsx"
  },
  "type": "module",
  "module": "src/index.tsx",
  "scripts": {
    "dev": "bun --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "test": "bun test",
    "check": "tsc --noEmit",
    "demo": "vhs assets/demo.tape",
    "demo:sessions": "vhs assets/sessions.tape",
    "demo:tabs": "vhs assets/tabs.tape",
    "demo:splits": "vhs assets/splits.tape",
    "demo:themes": "vhs assets/themes.tape",
    "restart-daemon": "bun run src/index.tsx restart-daemon",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@opentui/core": "^0.1.90",
    "@opentui/react": "^0.1.90",
    "@xterm/headless": "^6.0.0",
    "bun-pty": "^0.4.8",
    "react": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "eslint-plugin-perfectionist": "^5.8.0",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2"
  }
}
